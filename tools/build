#!/bin/bash
set -euo pipefail

PROJECT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
SOURCE=""
EXTRA=()

while [[ $# -gt 0 ]]; do
        case "$1" in
                -o) shift ;;
                -*) EXTRA+=("$1"); shift ;;
                *) SOURCE="$1"; shift ;;
        esac
done

if [[ -z "$SOURCE" ]]; then
        echo "Usage: build <source.cpp> [-o wasm] [flags...]" >&2
        exit 1
fi

OUT="${SOURCE%.*}"

SYSROOT="${WASI_SYSROOT:-$(for d in /usr/share/wasi-sysroot /opt/wasi-sdk/share/wasi-sysroot; do [[ -d "$d" ]] && echo "$d" && break; done)}"
if [[ -z "$SYSROOT" ]]; then
        echo "Error: wasi-sysroot not found. Install it or set WASI_SYSROOT." >&2
        exit 1
fi
exec "${WASI_SDK:+$WASI_SDK/bin/}clang++" --target=wasm32-wasip1 -std=c++23 -O2 --sysroot="$SYSROOT" -fno-exceptions -I"$PROJECT_DIR" -Wl,--export-memory "${EXTRA[@]}" "$SOURCE" -o "$OUT.wasm"
